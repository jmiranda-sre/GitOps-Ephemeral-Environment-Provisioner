# ── Application ──
APP_ENV=development              # development | staging | production
APP_PORT=3000
APP_VERSION=0.1.0
APP_BASE_DOMAIN=pr.localhost      # Base domain for ephemeral envs
APP_LOG_LEVEL=info                # debug | info | warn | error

# ── GitHub App ──
GITHUB_APP_ID=                    # GitHub App ID from settings
GITHUB_APP_PRIVATE_KEY_PATH=      # Path to private key .pem file
GITHUB_APP_WEBHOOK_SECRET=        # Webhook secret (min 32 chars)
GITHUB_APP_INSTALLATION_ID=       # Installation ID for the app

# ── Redis (Task Queue) ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Docker ──
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_COMPOSE_PATH=docker-compose.yml  # Default compose file in repos
DOCKER_NETWORK_PREFIX=eph-

# ── Traefik (Dynamic Router) ──
TRAEFIK_API_URL=http://localhost:8080
TRAEFIKEntryPoint=http
TRAEFIK_CERTRESOLVER=            # Leave empty for HTTP dev mode

# ── Secret Manager ──
SECRET_PROVIDER=env              # env | vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=                     # Vault root token (dev only)
VAULT_SECRET_PATH=ephemeral-env

# ── Resource Limits ──
MAX_CONCURRENT_ENVS=10
ENV_CPU_LIMIT=0.5               # CPU units per env
ENV_MEMORY_LIMIT=512m            # Memory per env
ENV_TTL_SECONDS=86400            # 24h default TTL
ENV_HIBERNATE_AFTER_SECONDS=3600 # 1h idle → hibernate

# ── Observability ──
METRICS_ENABLED=true
METRICS_PORT=9090
