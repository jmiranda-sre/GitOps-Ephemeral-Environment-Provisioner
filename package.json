{
  "name": "gitops-ephemeral-env-provisioner",
  "version": "0.1.0",
  "description": "GitOps Ephemeral Environment Provisioner — automated isolated test environments per PR",
  "main": "dist/server.js",
  "engines": { "node": ">=22.0.0" },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/formbody": "^7.4.0",
    "bullmq": "^5.8.3",
    "ioredis": "^5.4.1",
    "@octokit/auth-app": "^6.1.1",
    "@octokit/rest": "^20.1.1",
    "dotenv": "^16.4.5",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8",
    "dockerode": "^4.0.2",
    "uuid": "^10.0.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/uuid": "^9.0.8",
    "@types/dockerode": "^3.3.30",
    "typescript": "^5.5.3",
    "tsx": "^4.16.2",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "prettier": "^3.3.3",
    "undici": "^6.19.4"
  }
}
